{
  "expo": {
    "name": "Trailhead",
    "slug": "troop-trailhead",
    "version": "1.0.0",
    "scheme": "trailhead",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.yourtroop.trailhead",
      "supportsTablet": true
    },
    "android": {
      "package": "com.yourtroop.trailhead",
      "adaptiveIcon": { "backgroundColor": "#2b3d31" }
    },
    "web": { "bundler": "metro", "output": "single" },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": { "typedRoutes": true }
  }
}
